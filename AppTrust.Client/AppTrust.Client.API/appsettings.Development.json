{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Trust": { "Mode": "Both" },
  "AppTrustService": {
    "BaseUrl": "https://localhost:7214/"
  },
  "AppTrustClient": {
    "AcceptAnyServerCertificate": true,
    "TriggerApiKey": "dev-trigger-key",
    "ClientCertificatePath": "apptrust_client.pem",
    "PrivateKeyPath": "apptrust_client_private.pem"
  }
}